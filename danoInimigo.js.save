function danoInimigo() {
  let vidaInimigo = 100;
  let dano = Number(prompt("digite o valor do dano: "));
  let danoExtra = prompt("deseja dano extra? s/n");
  let danoextraValor = 20;
  if (dano > 0) {
    if (danoExtra === "s") {
      dano = dano + danoextraValor;
    } else if (danoExtra === "n") {
      dano = dano;
    } else {
      alert("resposta invalida");
    }
    vidaInimigo = vidaInimigo - dano;
    alert("vida do inimigo: " + vidaInimigo);
  }
}
